{
  "name": "casehub-blocks-ui",
  "version": "0.0.0",
  "description": "Shared UI components for CaseHub applications \u2014 composed from casehub-pages primitives",
  "repository": "https://github.com/casehubio/blocks-ui",
  "author": "Mark Proctor",
  "license": "Apache-2.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "components/*"
  ],
  "packageManager": "yarn@4.10.3",
  "scripts": {
    "build": "yarn workspaces foreach -A --topological run build",
    "typecheck": "tsc --build",
    "test": "yarn workspaces foreach -A run test",
    "clean": "yarn workspaces foreach -A run clean",
    "examples": "yarn --cwd examples dev"
  }
}
